---
import "@fontsource/mulish/400.css";
import "@fontsource/manrope/400.css";
import "../styles/global.css";
import WhatsappButton from "../components/WhatsappButton.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Galvez 1519 | Departamentos boutique",
  description = "2 y 3 Dormitorios. Encuentra el departamento perfecto para ti en el corazón de la ciudad.",
  image = "/images/og-image.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.url).href;
---

<!doctype html>
<html lang="es" class="bg-[#e2e1df]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/fonts/tan-pearl.woff2" as="font" type="font/woff2" crossorigin />

    <meta name="theme-color" content="#e2e1df" />

    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <slot name="head" />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "RealEstateListing",
        name: title,
        description: "Exclusivo proyecto residencial en El Tambo, Huancayo.",
        url: Astro.url.origin,
        image: socialImageURL,
        address: {
          "@type": "PostalAddress",
          streetAddress: "Jr. Mariano Gálvez 1519",
          addressLocality: "El Tambo",
          addressRegion: "Huancayo",
          addressCountry: "PE",
        },
      })}
    />
  </head>
  <body class="font-mulish text-gray-800 antialiased">
    <slot />
    <WhatsappButton />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
  }
</style>
