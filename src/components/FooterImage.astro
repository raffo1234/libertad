---
import { Image } from "astro:assets";
import outside from "../assets/outside.png";
import CircleArrow from "./CircleArrow";

const mainGallery = [{ src: outside, alt: "Galvez1519 | Fachada Exterior Premium" }];
---

<div id="main-outside-gallery" class="size-full">
  {
    mainGallery.map((img) => (
      <a
        href={img.src.src}
        data-pswp-width={img.src.width}
        data-pswp-height={img.src.height}
        target="_blank"
        class="main-img-link block size-full overflow-hidden rounded-[30px]"
      >
        <Image
          src={img.src}
          alt={img.alt}
          class="hover-boutique size-full rounded-[30px] object-cover object-left-top"
        />
      </a>
    ))
  }
  <button
    onclick="this.parentElement.querySelector('.main-img-link').click();"
    aria-label="Ver Imagen"
    class="absolute right-5 top-5 z-10"
  >
    <CircleArrow />
  </button>
</div>

<script>
  import { pswpConfig } from "../lib/photoswipe";
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import "photoswipe/dist/photoswipe.css";

  const mainLightbox = new PhotoSwipeLightbox({
    gallery: "#main-outside-gallery",
    children: "a.main-img-link",
    ...pswpConfig,
  });

  mainLightbox.init();
</script>
