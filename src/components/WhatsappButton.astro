---
import whatsapp from "../assets/whatsapp.svg";
import { Image } from "astro:assets";
---

<a
  href="https://wa.me/51988226088/?text=Quiero%20informaci%C3%B3n%20sobre%20los%20departamentos.%0AProyecto%20Galvez1519%2C%20El%20Tambo%20Huancayo%0AVengo%20de%20www.galvez1519.com"
  class="group fixed right-5 bottom-5 z-100 flex items-center rounded-full shadow-xl transition-all duration-300 hover:shadow-2xl active:scale-95"
  target="_blank"
  rel="noopener"
  style={{
    background: "rgba(30, 35, 45, 0.92)",
    backdropFilter: "blur(10px)",
    WebkitBackdropFilter: "blur(10px)",
  }}
>
  <div
    class="relative -left-px flex size-13 shrink-0 items-center justify-center rounded-full bg-[#25D366]"
  >
    <Image src={whatsapp} alt="Galvez1519 | Whatsapp" class="w-8" />
  </div>
  <div class="flex flex-col justify-center px-4 py-2">
    <span class="text-sm font-bold tracking-widest text-white uppercase">
      Asesoría personalizada
    </span>
    <span class="text-[10px] tracking-wider text-white/60 uppercase"> Compra tu depa </span>
  </div>
</a>
