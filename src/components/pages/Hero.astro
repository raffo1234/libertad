          ><use href="#ai:material-symbols-light:activity-zone-outline"></use>
        </svg>
        <div>
          <h3>Área</h3>
          <p><b>Desde <span class="font-nourd">81m<sup>2</sup></span> </b></p>
        </div>
      </article>
    </div>
    <div class="flex w-full items-center justify-around lg:w-1/2">
      <article class="flex items-center space-x-3">
        <svg
