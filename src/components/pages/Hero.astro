93.962t.963.403"
            ></path></symbol
          ><use href="#ai:material-symbols-light:graph-5"></use>
        </svg>
        <div><h3>Etapa</h3> <p><b>Lanzamiento</b></p></div>
      </article>
      <a
        href="#tipologias"
        class="flex items-center space-x-1 rounded-xl bg-amber-700 px-4 py-2 text-white transition-transform hover:scale-105 active:scale-95"
        title="Ver tipologías"
      >
        <svg width="40" height="40" data-icon="material-symbols-light:auto-awesome-mosaic-outline">
          <symbol id="ai:material-symbols-light:auto-awesome-mosaic-outline" viewBox="0 0 24 24"
            ><path
              fill="currentColor"
              d="M11 20H5.616q-.691 0-1.153-.462T4 18.384V5.616q0-.691.463-1.153T5.616 4H11zm-1-1V5H5.616q-.27 0-.443.173T5 5.616v12.769q0 .269.173.442t.443.173zm3-8V4h5.385q.69 0 1.152.463T20 5.616V11zm1-1h5V5.616q0-.27-.173-.443T18.385 5H14zm-1 10v-7h7v5.385q0 .69-.462 1.152T18.384 20zm1-1h4.385q.269 0 .442-.173t.173-.442V14h-5zm0-5"
