---
import HeroGallery from "../HeroGallery.astro";
---

<section class="relative mb-[40px]">
  <p class="text-center text-xl sm:text-2xl">Vive una experiencia única</p>
  <h2
    class="reveal text-nowrap text-center font-manrope leading-[1em]"
    style="font-size:clamp(24px, 10vw + 1rem, 160px)"
  >
    Hogar soñado
  </h2>
  <HeroGallery />
  <section
    class="absolute -bottom-9 left-0 w-full items-center rounded-[26px] bg-[#e0ddd5] py-5 drop-shadow-xl sm:left-1/2 sm:w-[70%] sm:-translate-x-1/2 sm:px-6 lg:flex lg:justify-between"
  >
    <h2 class="hidden">características</h2>
    <div class="mb-4 flex w-full items-center justify-around lg:mb-0 lg:w-1/2">
      <article class="flex items-center space-x-3">
        <svg
          width="40"
          height="40"
          class="text-amber-700"
          data-icon="material-symbols-light:king-bed-outline"
        >
          <symbol id="ai:material-symbols-light:king-bed-outline" viewBox="0 0 24 24"
            ><path
              fill="currentColor"
              d="M4.77 18h-.54l-.38-2H3v-3.39q0-.671.472-1.14q.472-.47 1.144-.47H5V8.615q0-.67.472-1.143Q5.944 7 6.616 7h10.769q.67 0 1.143.472q.472.472.472 1.143V11h.385q.67 0 1.143.472q.472.472.472 1.144V16h-.85l-.38 2h-.54l-.38-2H5.15zm7.73-7H18V8.615q0-.269-.173-.442T17.385 8H12.5zM6 11h5.5V8H6.616q-.27 0-.443.173T6 8.615zm-2 4h16v-2.384q0-.27-.173-.443T19.385 12H4.615q-.269 0-.442.173T4 12.616zm16 0H4z"
            ></path></symbol
          ><use href="#ai:material-symbols-light:king-bed-outline"></use>
        </svg>
        <div>
          <h3><span class="font-nourd">3</span> Dorms</h3>
          <p><b><span class="font-nourd">2</span> Baños</b></p>
        </div>
      </article>
      <article class="flex items-center space-x-3">
        <svg
          width="40"
          height="40"
          class="text-amber-700"
          data-icon="material-symbols-light:activity-zone-outline"
        >
          <symbol id="ai:material-symbols-light:activity-zone-outline" viewBox="0 0 24 24"
            ><path
              fill="currentColor"
              d="M5.77 20.23q-.834 0-1.417-.582q-.584-.584-.584-1.417q0-.706.428-1.238q.428-.531 1.072-.702V7.71q-.644-.171-1.072-.703t-.428-1.238q0-.833.584-1.416q.583-.584 1.416-.584q.706 0 1.238.428t.703 1.072h8.58q.166-.644.702-1.072t1.239-.428q.833 0 1.417.583q.583.584.583 1.417q0 .703-.428 1.24q-.428.535-1.072.7v8.582q.644.17 1.072.702t.428 1.238q0 .833-.583 1.417q-.584.583-1.417.583q-.706 0-1.238-.428q-.531-.428-.702-1.072H7.71q-.171.644-.703 1.072t-1.238.428m0-13.462q.425 0 .713-.287t.287-.713t-.287-.712t-.713-.288t-.712.288t-.288.712t.288.713t.712.287m12.462 0q.425 0 .712-.287t.288-.713t-.288-.712t-.712-.288t-.713.288t-.287.712t.287.713t.713.287M7.709 17.731h8.582q.148-.535.526-.914q.38-.378.914-.526V7.71q-.535-.13-.923-.518t-.518-.923H7.71q-.148.535-.527.914q-.38.378-.914.526v8.582q.535.148.914.526q.379.38.527.914m10.52 1.5q.426 0 .713-.288t.288-.712t-.288-.713t-.712-.287t-.713.287t-.287.713t.287.712t.713.288m-12.462 0q.425 0 .713-.288t.287-.712t-.287-.713t-.713-.287t-.712.287t-.288.713t.288.712t.712.288m0-1"
