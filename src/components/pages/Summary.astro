---
import { Image } from "astro:assets";
import outside from "../../assets/outside.jpg";
import { Icon } from "astro-icon/components";
---

<section>
  <div class="text-center">
    <h2 class="reveal mb-8 flex justify-center text-xl">
      <a
        href="/"
        title="Galvez 1519 - Hogar soñado en el corazón de El Tambo"
        class="flex items-center space-x-1 self-center font-tanPearl text-2xl tracking-wider"
      >
        <span class="pt-1">GALVEZ</span>
        <span class="rounded-md bg-[#795a45] px-2 pt-1.5 text-white"> 1519 </span>
      </a>
    </h2>
    <p class="reveal mx-auto mb-8 w-2/3 md:w-1/3">
      Diseño moderno, funcionalidad y comodidad en la ubicación ideal.
    </p>
  </div>
  <article
    class="reveal relative mx-auto h-[400px] w-full overflow-hidden rounded-[30px] sm:h-[600px] sm:w-3/4 lg:h-[816px] lg:w-1/2"
  >
    <h3>
      <Image src={outside} alt="Galvez1519" class="size-full object-cover object-top" />
      <button
        aria-label="Ver Imagen"
        class="absolute right-5 top-5 flex size-16 items-center justify-center rounded-full bg-amber-700 text-white"
      >
        <Icon name="material-symbols-light:arrow-outward-rounded" size="40" class="text-white" />
      </button>
    </h3>
  </article>
</section>
