---
import { Image } from "astro:assets";
import outside from "../../assets/outside.jpg";
import { Icon } from "astro-icon/components";
---

<section>
  <div class="text-center">
    <h2 class="mb-8 flex justify-center text-xl">
      <span class="flex items-center space-x-1 self-center font-manrope text-lg tracking-wider">
        <Icon name="material-symbols-light:home-work-outline-rounded" size="48" />
        <b class="block pt-2">Libertad</b>
      </span>
    </h2>
    <p class="mx-auto mb-8 w-2/3 md:w-1/3">
      Diseño moderno, funcionalidad y comodidad en la ubicación ideal.
    </p>
  </div>
  <article
    class="relative mx-auto h-[400px] w-full overflow-hidden rounded-[30px] sm:h-[600px] sm:w-3/4 lg:h-[816px] lg:w-1/2"
  >
    <h3>
      <Image src={outside} alt="Libertad" class="size-full object-cover object-top" />
      <button
        aria-label="Ver Imagen"
        class="absolute right-5 top-5 flex size-16 items-center justify-center rounded-full bg-[#ff9100] text-white"
      >
        <Icon name="material-symbols-light:arrow-outward-rounded" size="40" class="text-white" />
      </button>
    </h3>
  </article>
</section>
