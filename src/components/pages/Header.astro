    <LogoLink />
  </h1>
  <div class="absolute top-7 right-0 flex space-x-2">
    <a
      href="/docs/brochure-galvez1519.pdf"
      target="_blank"
      rel="noopener noreferrer"
      title="Ver brochure"
      aria-label="Ver Brochure"
      class="rounded-full bg-amber-700 px-4 py-3 text-xs text-white transition-transform hover:scale-[103%] active:scale-95 sm:px-6 sm:text-sm"
    >
      Brochure
    </a>
  </div>
</header>
