---
import { Image, getImage } from "astro:assets";
import image1 from "../assets/image1.jpg";
import image2 from "../assets/image2.jpg";
import image3 from "../assets/image3.jpg";
import image4 from "../assets/image4.jpg";
import image5 from "../assets/image5.jpg";

const rawImages = [
  { src: image1, alt: "Galvez 1519 | Fachada Boutique" },
  { src: image2, alt: "Galvez 1519 | Sala de estar" },
  { src: image3, alt: "Galvez 1519 | Dormitorio principal" },
  { src: image4, alt: "Galvez 1519 | Cocina integrada" },
  { src: image5, alt: "Galvez 1519 | Terraza" },
];

const lcpImage = await getImage({
  src: rawImages[0].src,
  width: 1200,
  format: "webp",
  quality: 85,
});

const secondaryImagesData = rawImages.slice(2).map((img) => ({
  full: img.src.src,
  display: img.src.src,
  width: img.src.width,
  height: img.src.height,
  alt: img.alt,
}));

const maskStyle =
  "mask-image: linear-gradient(to bottom, transparent 0%, black 2%, black 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 2%, black 100%);";
---

<slot name="head">
  <link rel="preload" as="image" href={lcpImage.src} fetchpriority="high" />
</slot>

<div
  id="gallery-container"
  class="pswp-gallery relative mt-[-2.5%] h-[540px] w-full overflow-hidden rounded-[50px]"
  data-secondary={JSON.stringify(secondaryImagesData)}
>
  <div
    class="pointer-events-none absolute left-0 top-0 z-20 h-[140px] w-full rounded-t-[50px]"
    style="backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px); mask-image: linear-gradient(to bottom, black 2%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 2%, transparent 100%);"
  >
  </div>

  <a
    href={rawImages[0].src.src}
    data-pswp-width={rawImages[0].src.width}
    data-pswp-height={rawImages[0].src.height}
    class="slide-js visible absolute inset-0 size-full cursor-pointer opacity-100 transition-opacity duration-1000"
  >
    <img
      src={lcpImage.src}
      alt={rawImages[0].alt}
      width={lcpImage.attributes.width}
      height={lcpImage.attributes.height}
      fetchpriority="high"
      loading="eager"
      decoding="sync"
      class="size-full rounded-[50px] object-cover"
      style={maskStyle}
    />
  </a>

  <a
    href={rawImages[1].src.src}
    data-pswp-width={rawImages[1].src.width}
    data-pswp-height={rawImages[1].src.height}
    class="slide-js invisible absolute inset-0 size-full cursor-pointer opacity-0 transition-opacity duration-1000"
  >
    <Image
      src={rawImages[1].src}
      alt={rawImages[1].alt}
      width={1200}
      loading="lazy"
      class="size-full rounded-[50px] object-cover"
      style={maskStyle}
    />
  </a>
</div>

<script>
  import { pswpConfig } from "../lib/photoswipe";
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import "photoswipe/dist/photoswipe.css";

  const container = document.getElementById("gallery-container") as HTMLElement;
  const secondaryData = JSON.parse(container.dataset.secondary || "[]");
  let slides = Array.from(container.querySelectorAll(".slide-js")) as HTMLElement[];
  let current = 0;
  let interval: number;

  const injectRemaining = () => {
    secondaryData.forEach((data: any) => {
      const a = document.createElement("a");
      a.href = data.full;
      a.className =
        "slide-js absolute inset-0 size-full opacity-0 invisible transition-opacity duration-1000";
      a.setAttribute("data-pswp-width", data.width);
      a.setAttribute("data-pswp-height", data.height);

      const img = document.createElement("img");
      img.src = data.display;
      img.alt = data.alt;
      img.loading = "lazy";
      img.className = "size-full rounded-[50px] object-cover";
      img.style.maskImage = "linear-gradient(to bottom, transparent 0%, black 2%, black 100%)";
      // @ts-ignore
      img.style.WebkitMaskImage =
        "linear-gradient(to bottom, transparent 0%, black 2%, black 100%)";

      a.appendChild(img);
      container.appendChild(a);
      slides.push(a);
    });

    if (slides.length > 1) startRotation();
  };

  if ("requestIdleCallback" in window) {
    window.requestIdleCallback(() => injectRemaining());
  } else {
    setTimeout(injectRemaining, 2000);
  }

  function goToSlide(nextIndex: number) {
    if (nextIndex === current) return;

    slides[current].classList.replace("opacity-100", "opacity-0");
    slides[current].classList.replace("visible", "invisible");

    current = nextIndex;

    slides[current].classList.replace("opacity-0", "opacity-100");
    slides[current].classList.replace("invisible", "visible");
  }

  const startRotation = () => {
    if (interval) clearInterval(interval);
    interval = window.setInterval(() => {
      if (document.querySelector(".pswp--open")) return;
      goToSlide((current + 1) % slides.length);
    }, 4500);
  };

  const lightbox = new PhotoSwipeLightbox({
    gallery: "#gallery-container",
    children: "a.slide-js",
    ...pswpConfig,
  });

  lightbox.init();

  lightbox.on("beforeOpen", () => {
    if (interval) clearInterval(interval);
    interval = 0;
  });

  lightbox.on("close", () => {
    const pswpIndex = lightbox.pswp?.currIndex;

    if (typeof pswpIndex === "number") {
      goToSlide(pswpIndex);
    }

    startRotation();
  });
</script>
