---
import { Image, getImage } from "astro:assets";
import image1 from "../assets/image1.jpg";
import image2 from "../assets/image2.jpg";
import image3 from "../assets/image3.jpg";
import image4 from "../assets/image4.jpg";
import image5 from "../assets/image5.jpg";

const rawImages = [
  { src: image1, alt: "Galvez1519 | Sala luminosa..." },
  { src: image2, alt: "Galvez1519 | Dormitorios..." },
  { src: image3, alt: "Galvez1519 | Espacio de estudio..." },
  { src: image4, alt: "Galvez1519 | Sala comedor..." },
  { src: image5, alt: "Galvez1519 | Habitación bien iluminada..." },
];

const firstImageOptimized = await getImage({ src: rawImages[0].src, width: 1200, format: "webp" });
const secondImageOptimized = await getImage({ src: rawImages[1].src, width: 1200, format: "webp" });

const priorityImages = [
  { ...rawImages[0], optimized: firstImageOptimized },
  { ...rawImages[1], optimized: secondImageOptimized },
];

const secondaryImagesData = rawImages.slice(2).map((img) => ({
  full: img.src.src,
  display: img.src.src,
  width: img.src.width,
  height: img.src.height,
  alt: img.alt,
}));
---

<link rel="preload" as="image" href={firstImageOptimized.src} fetchpriority="high" />

<div
  id="gallery-container"
  class="pswp-gallery relative mt-[-2.5%] h-[540px] w-full overflow-hidden rounded-[50px]"
  data-secondary={JSON.stringify(secondaryImagesData)}
>
  <div
    class="pointer-events-none absolute left-0 top-0 z-20 h-[140px] w-full rounded-t-[50px]"
    style={{
      backdropFilter: "blur(5px)",
      WebkitBackdropFilter: "blur(5px)",
      maskImage: "linear-gradient(to bottom, black 2%, transparent 100%)",
      WebkitMaskImage: "linear-gradient(to bottom, black 2%, transparent 100%)",
    }}
  >
  </div>

  {
    priorityImages.map((img, idx) => (
      <a
        id={idx === 0 ? "first-slide" : undefined}
        href={img.src.src}
        data-pswp-width={img.src.width}
        data-pswp-height={img.src.height}
        target="_blank"
        class={`slide-js absolute inset-0 size-full cursor-pointer transition-opacity duration-1000 ease-in-out ${idx === 0 ? "visible opacity-100" : "invisible opacity-0"}`}
      >
        <Image
          src={img.src}
          alt={img.alt}
          loading={idx === 0 ? "eager" : "lazy"}
          fetchpriority={idx === 0 ? "high" : "low"}
          decoding={idx === 0 ? "sync" : "async"}
          class="size-full rounded-[50px] object-cover"
          style={{
            maskImage: "linear-gradient(to bottom, transparent 0%, black 2%, black 100%)",
            WebkitMaskImage: "linear-gradient(to bottom, transparent 0%, black 2%, black 100%)",
            transform: "translateZ(0)",
          }}
        />
      </a>
    ))
  }
</div>

<script>
  import { pswpConfig } from "../lib/photoswipe";
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import "photoswipe/dist/photoswipe.css";

  const container = document.getElementById("gallery-container") as HTMLElement;
  const secondaryData = JSON.parse(container.dataset.secondary || "[]");

  let slides: HTMLElement[] = Array.from(container.querySelectorAll(".slide-js"));
  let current = 0;
  let carouselInterval: number | null = null;

  function lazyLoadImages() {
    secondaryData.forEach((data: any) => {
      const anchor = document.createElement("a");
      anchor.href = data.full;
      anchor.className =
        "slide-js absolute inset-0 size-full cursor-pointer opacity-0 invisible transition-opacity duration-1000 ease-in-out";
      anchor.setAttribute("data-pswp-width", data.width);
      anchor.setAttribute("data-pswp-height", data.height);
      anchor.target = "_blank";

      const img = document.createElement("img");
      img.src = data.display;
      img.alt = data.alt;
      img.className = "size-full rounded-[50px] object-cover";
      img.style.maskImage = "linear-gradient(to bottom, transparent 0%, black 2%, black 100%)";
      // @ts-ignore
      img.style.WebkitMaskImage =
        "linear-gradient(to bottom, transparent 0%, black 2%, black 100%)";

      anchor.appendChild(img);
      container.appendChild(anchor);
      slides.push(anchor);
    });
    if (slides.length > 1 && !carouselInterval) startCarousel();
  }

  if ("requestIdleCallback" in window) {
    window.requestIdleCallback(() => setTimeout(lazyLoadImages, 2000));
  } else {
    setTimeout(lazyLoadImages, 3000);
  }

  const lightbox = new PhotoSwipeLightbox({
    gallery: "#gallery-container",
    children: "a.slide-js",
    ...pswpConfig,
  });
  lightbox.init();

  function goToSlide(nextIndex: number) {
    if (!slides[current] || !slides[nextIndex]) return;
    slides[current].classList.replace("opacity-100", "opacity-0");
    slides[current].classList.replace("visible", "invisible");
    current = nextIndex;
    slides[current].classList.replace("opacity-0", "opacity-100");
    slides[current].classList.replace("invisible", "visible");
  }

  function startCarousel() {
    if (carouselInterval || slides.length <= 1) return;
    carouselInterval = window.setInterval(() => {
      if (!document.querySelector(".pswp--open")) {
        goToSlide((current + 1) % slides.length);
      }
    }, 3500);
  }

  if (slides.length > 1) startCarousel();

  lightbox.on("beforeOpen", () => {
    if (carouselInterval) clearInterval(carouselInterval);
    carouselInterval = null;
  });

  lightbox.on("close", () => {
    const index = lightbox.pswp?.currIndex;
    if (typeof index === "number") goToSlide(index);
    startCarousel();
  });
</script>
