---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/pages/Hero.astro";
import Header from "../components/pages/Header.astro";
import SharedAreas from "../components/pages/SharedAreas.astro";
import Location from "../components/pages/Location.astro";
import Summary from "../components/pages/Summary.astro";
import Footer from "../components/pages/Footer.astro";
import Typologies from "../components/Typologies.astro";
---

<Layout>
  <main class="mx-auto w-full max-w-screen-xl px-3 pb-4 sm:px-4">
    <Header />
    <Hero />
    <SharedAreas />
    <Typologies />
    <Location />
    <Summary />
    <Footer />
  </main>
</Layout>

<script>
  const observerOptions = {
    root: null,
    rootMargin: "0px",
    threshold: 0.1,
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("active");
      }
    });
  }, observerOptions);

  document.querySelectorAll(".reveal").forEach((section) => {
    observer.observe(section);
  });
</script>
