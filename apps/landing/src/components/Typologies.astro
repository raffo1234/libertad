---
import image1 from "../assets/interior-1.jpg";
import TypologyCard from "./TypologyCard.astro";

const typology1 = {
  title: "70m²",
  subtitle: "Tipo 1",
  floors: ["Piso 1"],
  image: image1,
  features: [
    { value: 3, label: "Dorms", isBold: true },
    { value: 2, label: "Baños", isBold: true },
    { value: "Kitchenette", label: "" },
    { value: "Sala / Comedor", label: "" },
    { value: "Centro de lavado", label: "" },
  ],
};

const typology2 = {
  title: "81m²",
  subtitle: "Tipo 2",
  image: image1,
  floors: ["Piso 1"],
  features: [
    { value: 3, label: "Dorms", isBold: true },
    { value: 2, label: "Baños", isBold: true },
    { value: "Kitchenette", label: "" },
    { value: "Sala / Comedor", label: "" },
    { value: "Centro de lavado", label: "" },
  ],
};

const typology3 = {
  title: "90m²",
  subtitle: "Tipo 3",
  floors: ["Piso 2", "Pisos 3 - 5, Balcón"],
  image: image1,
  features: [
    { value: 3, label: "Dorms", isBold: true },
    { value: 2, label: "Baños", isBold: true },
    { value: "Kitchenette", label: "" },
    { value: "Sala / Comedor", label: "" },
    { value: "Centro de lavado", label: "" },
  ],
};

const typology4 = {
  title: "100m²",
  subtitle: "Tipo 4",
  floors: ["Piso 2", "Pisos 3 - 5, Balcón"],
  image: image1,
  features: [
    { value: 3, label: "Dorms", isBold: true },
    { value: 2, label: "Baños", isBold: true },
    { value: "Kitchenette", label: "" },
    { value: "Sala / Comedor", label: "" },
    { value: "Centro de lavado", label: "" },
  ],
};

const typologies = [typology1, typology2, typology3, typology4];
---

<section id="tipologias" class="mb-[70px] overflow-hidden pt-12">
  <h2 class="reveal mx-auto mb-12 max-w-[70%] text-center text-xl">
    <b>¡Encuentra el departamento perfecto para ti!</b>
  </h2>

  <div class="embla reveal">
    <div class="embla__viewport">
      <div class="embla__container">
        {
          typologies.map((typo) => (
            <div class="embla__slide">
              <TypologyCard {...typo} />
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-6 flex items-center justify-center gap-2">
      <button
        class="embla__button--prev flex size-10 cursor-pointer items-center justify-center rounded-full border-none bg-[#E0DDD8] text-[#322014] transition hover:bg-[#807357] hover:text-white disabled:cursor-default disabled:opacity-30"
        aria-label="Anterior tipología"
      >
        <svg class="pointer-events-none size-[0.9rem]" viewBox="0 0 532 532">
          <path
            fill="currentColor"
            d="M355.66 11.354c13.793-13.805 36.208-13.805 50.001 0 13.785 13.804 13.785 36.238 0 50.034L201.22 266l204.442 204.61c13.785 13.805 13.785 36.239 0 50.044-13.793 13.796-36.208 13.796-50.002 0a5994246.277 5994246.277 0 0 0-229.332-229.454 35.065 35.065 0 0 1-10.326-25.126c0-9.2 3.393-18.26 10.326-25.2C172.192 194.973 332.731 34.31 355.66 11.354Z"
          ></path>
        </svg>
      </button>
      <button
        class="embla__button--next flex size-10 cursor-pointer items-center justify-center rounded-full border-none bg-[#E0DDD8] text-[#322014] transition hover:bg-[#807357] hover:text-white disabled:cursor-default disabled:opacity-30"
        aria-label="Siguiente tipología"
      >
        <svg class="pointer-events-none size-[0.9rem]" viewBox="0 0 532 532">
          <path
            fill="currentColor"
            d="M176.34 520.646c-13.793 13.805-36.208 13.805-50.001 0-13.785-13.804-13.785-36.238 0-50.034L330.78 266 126.34 61.391c-13.785-13.805-13.785-36.239 0-50.044 13.793-13.796 36.208-13.796 50.002 0 22.928 22.947 206.395 206.507 229.332 229.454a35.065 35.065 0 0 1 10.326 25.126c0 9.2-3.393 18.26-10.326 25.2-45.865 45.901-206.404 206.564-229.332 229.52Z"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .embla__viewport {
    overflow: hidden;
    width: 100%;
  }

  .embla__container {
    display: flex;
    touch-action: pan-y pinch-zoom;
    margin-left: -1rem;
  }

  .embla__slide {
    flex: 0 0 100%;
    min-width: 0;
    padding-left: 1rem;
  }

  @media (min-width: 1024px) {
    .embla__slide {
      flex: 0 0 50%;
    }
  }

  @keyframes embla-hint {
    0% {
      transform: translateX(0);
    }
    40% {
      transform: translateX(-5%);
    }
    70% {
      transform: translateX(-2%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .embla__container--hint {
    animation: embla-hint 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
</style>

<script>
  import { pswpConfig } from "../lib/photoswipe";
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import "photoswipe/dist/photoswipe.css";
  import EmblaCarousel from "embla-carousel";

  /* ── PhotoSwipe ── */
  const lightbox = new PhotoSwipeLightbox({
    gallery: ".pswp-gallery",
    children: "a",
    ...pswpConfig,
  });
  lightbox.init();

  /* ── Embla ── */
  const viewportNode = document.querySelector<HTMLElement>(".embla__viewport")!;
  const prevBtn = document.querySelector<HTMLButtonElement>(".embla__button--prev")!;
  const nextBtn = document.querySelector<HTMLButtonElement>(".embla__button--next")!;

  const embla = EmblaCarousel(viewportNode, {
    loop: false,
    align: "start",
    slidesToScroll: 1,
    containScroll: "trimSnaps",
  });

  const updateButtons = () => {
    prevBtn.disabled = !embla.canScrollPrev();
    nextBtn.disabled = !embla.canScrollNext();
  };

  embla.on("select", updateButtons);
  embla.on("reInit", updateButtons);
  updateButtons();

  prevBtn.addEventListener("click", () => embla.scrollPrev());
  nextBtn.addEventListener("click", () => embla.scrollNext());
</script>
